KAFKA_BOOTSTRAP_SERVERS = "localhost:9092"
KAFKA_TOPIC = "raw-market-data"

# Spark Configuration
SPARK_APP_NAME = "SparkKafkaConsumer"
SPARK_MASTER = "local[*]"  # Use all available cores

# This package is the "bridge" between Spark and Kafka
SPARK_KAFKA_PACKAGE = "org.apache.spark:spark-sql-kafka-0-10_2.12:3.5.0"

# Processing intervals
CHECKPOINT_LOCATION = "./checkpoints"
PROCESSING_INTERVAL = "10 seconds"